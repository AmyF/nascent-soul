[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/showcases/xiangqi/showcase.gd" id="1_scene"]
[ext_resource type="Theme" path="res://scenes/showcases/shared/demo_theme.tres" id="2_theme"]
[ext_resource type="PackedScene" path="res://scenes/showcases/xiangqi/board/xiangqi_board_surface.tscn" id="3_board_surface"]

[sub_resource type="StyleBoxFlat" id="XiangqiSidePanel"]
bg_color = Color(0.09, 0.11, 0.15, 0.98)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
border_color = Color(0.31, 0.45, 0.7, 1)
content_margin_left = 12.0
content_margin_top = 12.0
content_margin_right = 12.0
content_margin_bottom = 12.0
corner_radius_top_left = 14
corner_radius_top_right = 14
corner_radius_bottom_right = 14
corner_radius_bottom_left = 14

[node name="XiangqiShowcase" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("2_theme")

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoSceneMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="Toolbar" type="HBoxContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoToolbarFlow"

[node name="NewGameButton" type="Button" parent="RootMargin/RootVBox/Toolbar"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "New Game"

[node name="UndoButton" type="Button" parent="RootMargin/RootVBox/Toolbar"]
layout_mode = 2
theme_type_variation = &"DemoDangerActionButton"
disabled = true
text = "Undo"

[node name="ToolbarSpacer" type="Control" parent="RootMargin/RootVBox/Toolbar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="ContentRow" type="HBoxContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 18

[node name="BoardColumn" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_type_variation = &"DemoColumnVBox"

[node name="BoardPanel" parent="RootMargin/RootVBox/ContentRow/BoardColumn" instance=ExtResource("3_board_surface")]

[node name="InfoRow" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
custom_minimum_size = Vector2(244, 0)
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 12

[node name="TurnPanel" type="PanelContainer" parent="RootMargin/RootVBox/ContentRow/InfoRow"]
