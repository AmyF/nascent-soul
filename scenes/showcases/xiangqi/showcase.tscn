layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_styles/panel = SubResource("XiangqiSidePanel")

[node name="TurnVBox" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow/InfoRow/TurnPanel"]
layout_mode = 2
size_flags_vertical = 3
theme_override_constants/separation = 8

[node name="TurnHeading" type="Label" parent="RootMargin/RootVBox/ContentRow/InfoRow/TurnPanel/TurnVBox"]
