[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/main_menu.gd" id="1_scene"]
[ext_resource type="Theme" path="res://scenes/examples/shared/demo_theme.tres" id="2_theme"]
[ext_resource type="PackedScene" path="res://scenes/demo.tscn" id="3_demo"]
[ext_resource type="PackedScene" path="res://scenes/examples/freecell.tscn" id="4_freecell"]
[ext_resource type="PackedScene" path="res://scenes/examples/xiangqi.tscn" id="5_xiangqi"]
[ext_resource type="PackedScene" path="res://scenes/examples/transfer_playground.tscn" id="6_transfer"]
[ext_resource type="PackedScene" path="res://scenes/examples/layout_gallery.tscn" id="7_layouts"]
[ext_resource type="PackedScene" path="res://scenes/examples/policy_lab.tscn" id="8_rules"]
[ext_resource type="PackedScene" path="res://scenes/examples/zone_recipes.tscn" id="9_recipes"]
[ext_resource type="PackedScene" path="res://scenes/examples/battlefield_square_lab.tscn" id="10_square"]
[ext_resource type="PackedScene" path="res://scenes/examples/battlefield_hex_lab.tscn" id="11_hex"]
[ext_resource type="PackedScene" path="res://scenes/examples/battlefield_transfer_modes.tscn" id="12_modes"]
[ext_resource type="PackedScene" path="res://scenes/examples/targeting_lab.tscn" id="13_targeting"]

[sub_resource type="StyleBoxFlat" id="MainMenuSidebarPanel"]
bg_color = Color(0.14, 0.20, 0.29, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.28, 0.36, 0.46, 1)
corner_radius_top_left = 16
corner_radius_top_right = 16
corner_radius_bottom_right = 16
corner_radius_bottom_left = 16
content_margin_left = 16.0
content_margin_top = 16.0
content_margin_right = 16.0
content_margin_bottom = 16.0

[sub_resource type="StyleBoxFlat" id="MainMenuContentPanel"]
bg_color = Color(0.07, 0.11, 0.16, 1)
border_width_left = 1
border_width_top = 1
border_width_right = 1
border_width_bottom = 1
border_color = Color(0.25, 0.34, 0.45, 1)
corner_radius_top_left = 18
corner_radius_top_right = 18
corner_radius_bottom_right = 18
corner_radius_bottom_left = 18
content_margin_left = 12.0
content_margin_top = 12.0
content_margin_right = 12.0
content_margin_bottom = 12.0

[node name="MainMenu" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("2_theme")
demo_scene = ExtResource("3_demo")
transfer_scene = ExtResource("6_transfer")
layouts_scene = ExtResource("7_layouts")
rules_scene = ExtResource("8_rules")
recipes_scene = ExtResource("9_recipes")
square_scene = ExtResource("10_square")
hex_scene = ExtResource("11_hex")
modes_scene = ExtResource("12_modes")
targeting_scene = ExtResource("13_targeting")
freecell_scene = ExtResource("4_freecell")
xiangqi_scene = ExtResource("5_xiangqi")

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoHubMargin"

[node name="RootHBox" type="HBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_override_constants/separation = 18

[node name="Sidebar" type="PanelContainer" parent="RootMargin/RootHBox"]
custom_minimum_size = Vector2(280, 0)
layout_mode = 2
theme_override_styles/panel = SubResource("MainMenuSidebarPanel")

[node name="SidebarVBox" type="VBoxContainer" parent="RootMargin/RootHBox/Sidebar"]
layout_mode = 2
theme_override_constants/separation = 14

[node name="TitleLabel" type="Label" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoHubTitle"
text = "NascentSoul Launcher"

[node name="SummaryLabel" type="Label" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "Transfer、Layouts、Rules、Recipes、Square、Hex、Modes、Targeting、FreeCell、Xiangqi 都从这里直接进入；不再需要先经过 Demo Lab。"

[node name="TransferButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Transfer"
metadata/entry_scene_key = "transfer"
metadata/entry_title = "Transfer"
metadata/entry_summary = "Inspect linear transfers between deck, hand, board, and discard from the launcher."

[node name="LayoutsButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Layouts"
metadata/entry_scene_key = "layouts"
metadata/entry_title = "Layouts"
metadata/entry_summary = "Compare row, hand, grouped list, and pile layouts in one standalone scene."

[node name="RulesButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Rules"
metadata/entry_scene_key = "rules"
metadata/entry_title = "Rules"
metadata/entry_summary = "Explore transfer restrictions, source checks, and capacity limits in the policy-focused demo."

[node name="RecipesButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Recipes"
metadata/entry_scene_key = "recipes"
metadata/entry_title = "Recipes"
metadata/entry_summary = "Review the starter four-column recipe and its serialized zone setup."

[node name="SquareButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Square"
metadata/entry_scene_key = "square"
metadata/entry_title = "Square"
metadata/entry_summary = "Inspect square-grid battlefield placement and return flows."

[node name="HexButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Hex"
metadata/entry_scene_key = "hex"
metadata/entry_title = "Hex"
metadata/entry_summary = "Inspect hex-grid battlefield placement and return flows."

[node name="ModesButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Modes"
metadata/entry_scene_key = "modes"
metadata/entry_title = "Modes"
metadata/entry_summary = "Compare direct placement and spawn-piece transfer modes."

[node name="TargetingButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Targeting"
metadata/entry_scene_key = "targeting"
metadata/entry_title = "Targeting"
metadata/entry_summary = "Preview targeting presets and style overrides."

[node name="FreeCellButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "FreeCell"
metadata/entry_scene_key = "freecell"
metadata/entry_title = "FreeCell"
metadata/entry_summary = "Launch the classic Windows XP style FreeCell implementation."

[node name="XiangqiButton" type="Button" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "Xiangqi"
metadata/entry_scene_key = "xiangqi"
metadata/entry_title = "Xiangqi"
metadata/entry_summary = "Launch the standalone Xiangqi board."

[node name="SidebarFiller" type="Control" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
size_flags_vertical = 3

[node name="HintLabel" type="Label" parent="RootMargin/RootHBox/Sidebar/SidebarVBox"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "The content panel on the right swaps scenes in place, so you can jump between all 10 entries without leaving the app."

[node name="ContentColumn" type="VBoxContainer" parent="RootMargin/RootHBox"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_constants/separation = 10

[node name="ContentTitleLabel" type="Label" parent="RootMargin/RootHBox/ContentColumn"]
layout_mode = 2
theme_type_variation = &"DemoBlueHeading"
text = "Main Menu"

[node name="ContentSummaryLabel" type="Label" parent="RootMargin/RootHBox/ContentColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "Pick one of the 10 entries from the left."

[node name="ContentPanel" type="PanelContainer" parent="RootMargin/RootHBox/ContentColumn"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_styles/panel = SubResource("MainMenuContentPanel")

[node name="ContentHost" type="Control" parent="RootMargin/RootHBox/ContentColumn/ContentPanel"]
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
