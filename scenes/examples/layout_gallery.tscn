[node name="LayoutGallery" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("10_theme")
gallery_cards = [SubResource("LayoutCardPulse"), SubResource("LayoutCardWard"), SubResource("LayoutCardAnchor"), SubResource("LayoutCardBurst"), SubResource("LayoutCardLoom")]

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoSceneMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="Toolbar" type="HFlowContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoToolbarFlow"

[node name="SortButton" type="Button" parent="RootMargin/RootVBox/Toolbar"]
layout_mode = 2
