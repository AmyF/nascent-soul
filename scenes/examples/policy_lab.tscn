[node name="PolicyLab" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("12_theme")
deck_cards = [SubResource("PolicyDeckCardRune"), SubResource("PolicyDeckCardShard"), SubResource("PolicyDeckCardBeacon"), SubResource("PolicyDeckCardMirror")]
hand_cards = [SubResource("PolicyHandCardBloom"), SubResource("PolicyHandCardTrace"), SubResource("PolicyHandCardArc")]

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoSceneMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="Grid" type="GridContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
columns = 5
theme_type_variation = &"DemoPolicyGrid"

[node name="DeckColumn" type="VBoxContainer" parent="RootMargin/RootVBox/Grid"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
theme_type_variation = &"DemoColumnVBox"

