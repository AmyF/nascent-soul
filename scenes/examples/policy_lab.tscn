[sub_resource type="Resource" id="PolicyDeckPileLayout"]
script = ExtResource("7_pile_layout")
overlap_x = 16.0

[sub_resource type="Resource" id="PolicyBoardCapacityPolicy"]
script = ExtResource("9_policy_capacity")
max_items = 2
reject_reason = "Board 在这个实验里只允许 2 张牌。\nBoard only allows two cards in this lab."

[sub_resource type="Resource" id="PolicySanctumLayout"]
script = ExtResource("8_vbox_layout")
item_spacing = 10.0
padding_top = 14.0

[sub_resource type="Resource" id="PolicySanctumSourcePolicy"]
script = ExtResource("10_policy_source")
allowed_source_zone_names = PackedStringArray("HandZone")
reject_reason = "Sanctum 只接收来自 HandZone 的卡牌。\nSanctum only accepts cards that come from HandZone."

[sub_resource type="Resource" id="PolicySanctumCapacityPolicy"]
script = ExtResource("9_policy_capacity")
max_items = 2
reject_reason = "Sanctum 在这个实验里也只允许 2 张牌。\nSanctum also allows only two cards in this lab."

[sub_resource type="Resource" id="PolicySanctumCompositePolicy"]
script = ExtResource("11_policy_composite")
policies = [SubResource("PolicySanctumSourcePolicy"), SubResource("PolicySanctumCapacityPolicy")]

[sub_resource type="Resource" id="PolicyDeckCardRune"]
script = ExtResource("13_card_spec")
