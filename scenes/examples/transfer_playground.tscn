[node name="TransferPlayground" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("9_theme")
deck_cards = [SubResource("TransferDeckCardSpark"), SubResource("TransferDeckCardShell"), SubResource("TransferDeckCardFocus"), SubResource("TransferDeckCardGale"), SubResource("TransferDeckCardEcho"), SubResource("TransferDeckCardNova")]
hand_cards = [SubResource("TransferHandCardTether"), SubResource("TransferHandCardBloom"), SubResource("TransferHandCardStrike"), SubResource("TransferHandCardWard"), SubResource("TransferHandCardOrbit")]
board_cards = [SubResource("TransferBoardCardSentinel"), SubResource("TransferBoardCardPulse")]

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
