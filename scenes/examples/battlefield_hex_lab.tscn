[sub_resource type="Resource" id="HexSourceLayout"]
script = ExtResource("8_hbox_layout")
item_spacing = 16.0
padding_left = 16.0
padding_top = 18.0

[sub_resource type="Resource" id="HexSourceDisplay"]
script = ExtResource("9_display")

[sub_resource type="Resource" id="HexSourceInteraction"]
script = ExtResource("10_interaction")

[sub_resource type="Resource" id="HexSourceSort"]
script = ExtResource("11_sort")

[sub_resource type="Resource" id="HexSourcePolicy"]
script = ExtResource("12_allow_all")

[sub_resource type="Resource" id="HexSourceSpace"]
script = ExtResource("13_linear_space")

[sub_resource type="Resource" id="HexSourceFactory"]
script = ExtResource("14_factory")

[sub_resource type="Resource" id="HexSourceZoneConfig"]
script = ExtResource("7_config")
space_model = SubResource("HexSourceSpace")
layout_policy = SubResource("HexSourceLayout")
display_style = SubResource("HexSourceDisplay")
interaction = SubResource("HexSourceInteraction")
sort_policy = SubResource("HexSourceSort")
transfer_policy = SubResource("HexSourcePolicy")
drag_visual_factory = SubResource("HexSourceFactory")

[sub_resource type="Resource" id="HexBattlefieldSpace"]
script = ExtResource("15_hex_space")
columns = 4
rows = 3
cell_size = Vector2(116, 100)
cell_spacing_x = 10.0
row_spacing = 12.0
padding = Vector2(20, 20)

[node name="BattlefieldHexLab" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("2_theme")
ready_status = "双击卡牌进入六边形战场，右键返回 / Double-click cards into the hex battlefield, right-click to return"
source_widths = Vector3(320, 232, 216)
battlefield_gap_widths = Vector3(96, 72, 56)
battlefield_width_limits_desktop = Vector2(520, 560)
battlefield_width_limits_compact = Vector2(500, 540)
battlefield_width_limits_mobile = Vector2(480, 520)
source_panel_heights = Vector3(220, 200, 184)
battlefield_panel_heights = Vector3(420, 400, 380)
battlefield_min_scale = 0.82

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoHubMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="TitleLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoHubTitle"
text = "Hex Battlefield / 六边形战场"

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoStatusLabel"
