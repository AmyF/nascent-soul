[ext_resource type="Script" path="res://addons/nascentsoul/resources/zone_interaction.gd" id="10_interaction"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/sorts/zone_manual_sort.gd" id="11_sort"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_allow_all_transfer_policy.gd" id="12_allow_all"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_linear_space_model.gd" id="13_linear_space"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/factories/zone_configurable_drag_visual_factory.gd" id="14_factory"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_square_grid_space_model.gd" id="15_square_space"]

[sub_resource type="Resource" id="SquareSourceLayout"]
script = ExtResource("8_hbox_layout")
item_spacing = 16.0
padding_left = 16.0
padding_top = 18.0

[sub_resource type="Resource" id="SquareSourceDisplay"]
script = ExtResource("9_display")

[sub_resource type="Resource" id="SquareSourceInteraction"]
script = ExtResource("10_interaction")

[sub_resource type="Resource" id="SquareSourceSort"]
script = ExtResource("11_sort")

[sub_resource type="Resource" id="SquareSourcePolicy"]
script = ExtResource("12_allow_all")

[sub_resource type="Resource" id="SquareSourceSpace"]
script = ExtResource("13_linear_space")

[sub_resource type="Resource" id="SquareSourceFactory"]
script = ExtResource("14_factory")

[sub_resource type="Resource" id="SquareSourceZoneConfig"]
script = ExtResource("7_config")
space_model = SubResource("SquareSourceSpace")
layout_policy = SubResource("SquareSourceLayout")
display_style = SubResource("SquareSourceDisplay")
interaction = SubResource("SquareSourceInteraction")
sort_policy = SubResource("SquareSourceSort")
transfer_policy = SubResource("SquareSourcePolicy")
drag_visual_factory = SubResource("SquareSourceFactory")

[sub_resource type="Resource" id="SquareBattlefieldSpace"]
script = ExtResource("15_square_space")
columns = 4
rows = 3
cell_size = Vector2(120, 120)
cell_spacing = Vector2(12, 12)
padding = Vector2(20, 20)

[node name="BattlefieldSquareLab" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("2_theme")
ready_status = "双击卡牌进入方格战场，右键战场牌回手牌 / Double-click cards into the square battlefield, right-click them to return"
source_widths = Vector3(320, 232, 216)
battlefield_gap_widths = Vector3(96, 72, 56)
battlefield_width_limits_desktop = Vector2(460, 520)
battlefield_width_limits_compact = Vector2(440, 500)
battlefield_width_limits_mobile = Vector2(440, 480)
source_panel_heights = Vector3(220, 200, 184)
battlefield_panel_heights = Vector3(420, 400, 380)
battlefield_min_cell_size = 92.0

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoHubMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="TitleLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoHubTitle"
text = "Square Battlefield / 方格战场"

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoStatusLabel"
autowrap_mode = 3
theme_override_colors/font_color = Color(0.97, 0.98, 1, 1)
text = "最近 / Latest: 双击卡牌进入方格战场，右键战场牌回手牌 / Double-click cards into the square battlefield, right-click them to return"

[node name="ContentRow" type="HFlowContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
theme_type_variation = &"DemoWideFlow"

[node name="SourceColumn" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="SourceLabel" type="Label" parent="RootMargin/RootVBox/ContentRow/SourceColumn"]
layout_mode = 2
theme_type_variation = &"DemoGoldHeading"
