[node name="BattlefieldColumn" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="BattlefieldLabel" type="Label" parent="RootMargin/RootVBox/ContentRow/BattlefieldColumn"]
layout_mode = 2
theme_type_variation = &"DemoBlueHeading"
text = "Battlefield"

[node name="BattlefieldPanel" type="Panel" parent="RootMargin/RootVBox/ContentRow/BattlefieldColumn"]
