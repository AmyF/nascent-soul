[ext_resource type="Script" path="res://addons/nascentsoul/resources/zone_interaction.gd" id="10_interaction"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/sorts/zone_manual_sort.gd" id="11_sort"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_linear_space_model.gd" id="12_linear_space"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/factories/zone_configurable_drag_visual_factory.gd" id="13_factory"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_square_grid_space_model.gd" id="14_square_space"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_occupancy_transfer_policy.gd" id="15_occupancy"]
