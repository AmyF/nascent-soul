[ext_resource type="Script" path="res://addons/nascentsoul/pieces/zone_piece.gd" id="20_zone_piece"]

[sub_resource type="Resource" id="ModesSourceLayout"]
script = ExtResource("8_hbox_layout")
item_spacing = 16.0
padding_left = 16.0
padding_top = 18.0

[sub_resource type="Resource" id="ModesSourceDisplay"]
script = ExtResource("9_display")

[sub_resource type="Resource" id="ModesSourceInteraction"]
script = ExtResource("10_interaction")

[sub_resource type="Resource" id="ModesSourceSort"]
script = ExtResource("11_sort")

[sub_resource type="Resource" id="ModesSourceSpace"]
script = ExtResource("12_linear_space")

[sub_resource type="Resource" id="ModesSourceFactory"]
script = ExtResource("13_factory")

[sub_resource type="Resource" id="ModesCardsOnlyRule"]
script = ExtResource("18_transfer_rule")
source_item_script = ExtResource("20_zone_piece")
allowed = false
reject_reason = "Cards 只接受卡牌，不能接收已生成的棋子。\nCards only accept cards, not spawned pieces."

[sub_resource type="Resource" id="ModesCardsOnlyPolicy"]
script = ExtResource("17_rule_table")
rules = [SubResource("ModesCardsOnlyRule")]

[sub_resource type="Resource" id="ModesSourceZoneConfig"]
script = ExtResource("7_config")
space_model = SubResource("ModesSourceSpace")
layout_policy = SubResource("ModesSourceLayout")
display_style = SubResource("ModesSourceDisplay")
interaction = SubResource("ModesSourceInteraction")
sort_policy = SubResource("ModesSourceSort")
transfer_policy = SubResource("ModesCardsOnlyPolicy")
drag_visual_factory = SubResource("ModesSourceFactory")

[sub_resource type="Resource" id="ModesDirectSpace"]
script = ExtResource("14_square_space")
columns = 3
rows = 2
cell_size = Vector2(120, 120)
cell_spacing = Vector2(12, 12)
padding = Vector2(20, 20)

[sub_resource type="Resource" id="ModesDirectOccupancy"]
script = ExtResource("15_occupancy")

[sub_resource type="Resource" id="ModesDirectCompositePolicy"]
script = ExtResource("16_composite")
policies = [SubResource("ModesDirectOccupancy"), SubResource("ModesCardsOnlyPolicy")]

[sub_resource type="Resource" id="ModesSummonSpace"]
script = ExtResource("14_square_space")
columns = 3
rows = 2
cell_size = Vector2(120, 120)
cell_spacing = Vector2(12, 12)
padding = Vector2(20, 20)

[sub_resource type="Resource" id="ModesSummonOccupancy"]
script = ExtResource("15_occupancy")

[sub_resource type="Resource" id="ModesSummonRule"]
script = ExtResource("18_transfer_rule")
source_item_script = ExtResource("19_zone_card")
target_kind = 2
transfer_mode = 1

[sub_resource type="Resource" id="ModesSummonRuleTable"]
script = ExtResource("17_rule_table")
rules = [SubResource("ModesSummonRule")]

[sub_resource type="Resource" id="ModesSummonCompositePolicy"]
script = ExtResource("16_composite")
policies = [SubResource("ModesSummonOccupancy"), SubResource("ModesSummonRuleTable")]

[node name="BattlefieldTransferModes" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("2_theme")
ready_status = "源区双击进入 Direct Place 并保持卡牌；源区右键进入 Spawn Piece 并生成棋子；生成的棋子默认不能回到 Cards 或 Direct Place / Double-click in source to enter Direct Place as a card; right-click in source to enter Spawn Piece and become a piece; spawned pieces do not return to Cards or Direct Place by default"
source_widths = Vector3(240, 212, 180)
battlefield_widths = Vector3(340, 292, 280)
source_panel_heights = Vector3(220, 196, 180)
battlefield_panel_heights = Vector3(320, 296, 280)
battlefield_min_cell_size = 88.0

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoHubMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="TitleLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoHubTitle"
text = "Transfer Modes / 直接落牌与生成棋子"

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoStatusLabel"
autowrap_mode = 3
theme_override_colors/font_color = Color(0.97, 0.98, 1, 1)
text = "最近 / Latest: 源区双击进入 Direct Place 并保持卡牌；源区右键进入 Spawn Piece 并生成棋子；生成的棋子默认不能回到 Cards 或 Direct Place / Double-click in source to enter Direct Place as a card; right-click in source to enter Spawn Piece and become a piece; spawned pieces do not return to Cards or Direct Place by default"

[node name="ContentRow" type="HFlowContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
theme_type_variation = &"DemoWideFlow"

[node name="SourceColumn" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="SourceLabel" type="Label" parent="RootMargin/RootVBox/ContentRow/SourceColumn"]
