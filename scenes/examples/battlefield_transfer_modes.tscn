[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_rule_table_transfer_policy.gd" id="17_rule_table"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_transfer_rule.gd" id="18_transfer_rule"]
