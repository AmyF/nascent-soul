[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/examples/permission_lab.gd" id="1_scene"]
[ext_resource type="Theme" path="res://scenes/examples/shared/demo_theme.tres" id="12_theme"]
[ext_resource type="Script" path="res://scenes/examples/shared/example_card_spec.gd" id="13_card_spec"]
[ext_resource type="Script" path="res://addons/nascentsoul/core/zone.gd" id="2_zone"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/pile_zone_preset.tres" id="3_pile"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/hand_zone_preset.tres" id="4_hand"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/board_zone_preset.tres" id="5_board"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/discard_zone_preset.tres" id="6_discard"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/layouts/zone_pile_layout.gd" id="7_pile_layout"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/layouts/zone_vbox_layout.gd" id="8_vbox_layout"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_capacity_permission.gd" id="9_capacity"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_source_permission.gd" id="10_source"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_composite_permission.gd" id="11_composite"]

[sub_resource type="Resource" id="PermissionDeckPileLayout"]
script = ExtResource("7_pile_layout")
overlap_x = 16.0

[sub_resource type="Resource" id="PermissionBoardCapacityPermission"]
script = ExtResource("9_capacity")
max_items = 2
reject_reason = "Board 在这个实验里只允许 2 张牌。\nBoard only allows two cards in this lab."

[sub_resource type="Resource" id="PermissionSanctumLayout"]
script = ExtResource("8_vbox_layout")
item_spacing = 10.0
padding_top = 14.0

[sub_resource type="Resource" id="PermissionSanctumSourcePermission"]
script = ExtResource("10_source")
allowed_source_zone_names = PackedStringArray("HandZone")
reject_reason = "Sanctum 只接收来自 HandZone 的卡牌。\nSanctum only accepts cards that come from HandZone."

[sub_resource type="Resource" id="PermissionSanctumCapacityPermission"]
script = ExtResource("9_capacity")
max_items = 2
reject_reason = "Sanctum 在这个实验里也只允许 2 张牌。\nSanctum also allows only two cards in this lab."

[sub_resource type="Resource" id="PermissionSanctumCompositePermission"]
script = ExtResource("11_composite")
policies = [SubResource("PermissionSanctumSourcePermission"), SubResource("PermissionSanctumCapacityPermission")]

[sub_resource type="Resource" id="PermissionDeckCardRune"]
script = ExtResource("13_card_spec")
title = "Rune"
cost = 1
tags = PackedStringArray("skill")

[sub_resource type="Resource" id="PermissionDeckCardShard"]
script = ExtResource("13_card_spec")
title = "Shard"
cost = 1
tags = PackedStringArray("attack")

[sub_resource type="Resource" id="PermissionDeckCardBeacon"]
script = ExtResource("13_card_spec")
title = "Beacon"
cost = 2
tags = PackedStringArray("power")

[sub_resource type="Resource" id="PermissionDeckCardMirror"]
script = ExtResource("13_card_spec")
title = "Mirror"
cost = 2
tags = PackedStringArray("skill")

[sub_resource type="Resource" id="PermissionHandCardBloom"]
script = ExtResource("13_card_spec")
title = "Bloom"
cost = 2
tags = PackedStringArray("power")

[sub_resource type="Resource" id="PermissionHandCardTrace"]
script = ExtResource("13_card_spec")
title = "Trace"
cost = 1
tags = PackedStringArray("skill")

[sub_resource type="Resource" id="PermissionHandCardArc"]
script = ExtResource("13_card_spec")
title = "Arc"
cost = 1
tags = PackedStringArray("attack")

