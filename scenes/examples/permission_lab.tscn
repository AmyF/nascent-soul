[node name="PermissionLab" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("12_theme")
deck_cards = [SubResource("PermissionDeckCardRune"), SubResource("PermissionDeckCardShard"), SubResource("PermissionDeckCardBeacon"), SubResource("PermissionDeckCardMirror")]
hand_cards = [SubResource("PermissionHandCardBloom"), SubResource("PermissionHandCardTrace"), SubResource("PermissionHandCardArc")]

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoSceneMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="Grid" type="GridContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
columns = 5
theme_type_variation = &"DemoPermissionGrid"

[node name="DeckColumn" type="VBoxContainer" parent="RootMargin/RootVBox/Grid"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="DeckLabel" type="Label" parent="RootMargin/RootVBox/Grid/DeckColumn"]
layout_mode = 2
theme_type_variation = &"DemoGoldHeading"
text = "牌库 / Deck"

[node name="DeckZone" type="Control" parent="RootMargin/RootVBox/Grid/DeckColumn"]
custom_minimum_size = Vector2(160, 220)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("PermissionDeckZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("3_pile")
layout_policy = SubResource("PermissionDeckPileLayout")

[node name="HandColumn" type="VBoxContainer" parent="RootMargin/RootVBox/Grid"]
layout_mode = 2
custom_minimum_size = Vector2(180, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="HandLabel" type="Label" parent="RootMargin/RootVBox/Grid/HandColumn"]
layout_mode = 2
theme_type_variation = &"DemoGreenHeading"
text = "手牌 / Hand"

[node name="HandZone" type="Control" parent="RootMargin/RootVBox/Grid/HandColumn"]
custom_minimum_size = Vector2(180, 220)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("PermissionHandZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("4_hand")

[node name="BoardColumn" type="VBoxContainer" parent="RootMargin/RootVBox/Grid"]
layout_mode = 2
custom_minimum_size = Vector2(180, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="BoardLabel" type="Label" parent="RootMargin/RootVBox/Grid/BoardColumn"]
layout_mode = 2
theme_type_variation = &"DemoBlueHeading"
text = "战场 / Board"

[node name="BoardRuleLabel" type="Label" parent="RootMargin/RootVBox/Grid/BoardColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "任意来源 / Any source"

[node name="BoardCapacityLabel" type="Label" parent="RootMargin/RootVBox/Grid/BoardColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "容量 0 / 2 / Capacity 0 / 2"

[node name="BoardZone" type="Control" parent="RootMargin/RootVBox/Grid/BoardColumn"]
custom_minimum_size = Vector2(180, 220)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("PermissionBoardZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("5_board")
permission_policy = SubResource("PermissionBoardCapacityPermission")

[node name="SanctumColumn" type="VBoxContainer" parent="RootMargin/RootVBox/Grid"]
layout_mode = 2
custom_minimum_size = Vector2(180, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="SanctumLabel" type="Label" parent="RootMargin/RootVBox/Grid/SanctumColumn"]
layout_mode = 2
theme_type_variation = &"DemoVioletHeading"
text = "圣所 / Sanctum"

[node name="SanctumRuleLabel" type="Label" parent="RootMargin/RootVBox/Grid/SanctumColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "仅 HandZone / HandZone only"

[node name="SanctumCapacityLabel" type="Label" parent="RootMargin/RootVBox/Grid/SanctumColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "容量 0 / 2 / Capacity 0 / 2"

[node name="SanctumZone" type="Control" parent="RootMargin/RootVBox/Grid/SanctumColumn"]
custom_minimum_size = Vector2(180, 220)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("PermissionSanctumZonePanel")
script = ExtResource("2_zone")
layout_policy = SubResource("PermissionSanctumLayout")
permission_policy = SubResource("PermissionSanctumCompositePermission")

[node name="DiscardColumn" type="VBoxContainer" parent="RootMargin/RootVBox/Grid"]
layout_mode = 2
custom_minimum_size = Vector2(160, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="DiscardLabel" type="Label" parent="RootMargin/RootVBox/Grid/DiscardColumn"]
layout_mode = 2
theme_type_variation = &"DemoRoseHeading"
text = "弃牌堆 / Discard"

[node name="DiscardZone" type="Control" parent="RootMargin/RootVBox/Grid/DiscardColumn"]
custom_minimum_size = Vector2(160, 220)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("PermissionDiscardZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("6_discard")

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoStatusLabel"
text = "最近 / Latest: Loading permission lab..."
