[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/examples/targeting_lab.gd" id="1_scene"]
[ext_resource type="Theme" path="res://scenes/examples/shared/demo_theme.tres" id="2_theme"]
[ext_resource type="Script" path="res://addons/nascentsoul/core/zone.gd" id="3_zone"]
[ext_resource type="Script" path="res://addons/nascentsoul/core/battlefield_zone.gd" id="4_battlefield_zone"]
[ext_resource type="Script" path="res://scenes/examples/shared/example_zone_card.gd" id="5_example_card"]
[ext_resource type="Script" path="res://scenes/examples/shared/example_zone_piece.gd" id="6_example_piece"]
[ext_resource type="Script" path="res://addons/nascentsoul/resources/zone_config.gd" id="7_config"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/layouts/zone_hbox_layout.gd" id="8_hbox_layout"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/displays/zone_card_display.gd" id="9_display"]
[ext_resource type="Script" path="res://addons/nascentsoul/resources/zone_interaction.gd" id="10_interaction"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/sorts/zone_manual_sort.gd" id="11_sort"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_allow_all_transfer_policy.gd" id="12_allow_all"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_linear_space_model.gd" id="13_linear_space"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/factories/zone_configurable_drag_visual_factory.gd" id="14_factory"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_square_grid_space_model.gd" id="15_square_space"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/targeting/zone_target_rule_table_policy.gd" id="16_target_rule_table"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/targeting/zone_target_rule.gd" id="17_target_rule"]
[ext_resource type="Script" path="res://addons/nascentsoul/model/zone_targeting_intent.gd" id="18_target_intent"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/targeting/classic_arrow_targeting_style.tres" id="19_classic_style"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/targeting/zone_target_allow_all_policy.gd" id="20_target_allow_all"]
[ext_resource type="Script" path="res://addons/nascentsoul/pieces/zone_piece.gd" id="21_zone_piece"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/layouts/zone_battlefield_layout.gd" id="22_battlefield_layout"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_occupancy_transfer_policy.gd" id="23_occupancy_policy"]

[sub_resource type="Resource" id="TargetingSpellLayout"]
script = ExtResource("8_hbox_layout")
item_spacing = 16.0
padding_left = 16.0
padding_top = 18.0

[sub_resource type="Resource" id="TargetingSpellDisplay"]
script = ExtResource("9_display")

[sub_resource type="Resource" id="TargetingSpellInteraction"]
script = ExtResource("10_interaction")

[sub_resource type="Resource" id="TargetingSpellSort"]
script = ExtResource("11_sort")

[sub_resource type="Resource" id="TargetingSpellTransferPolicy"]
script = ExtResource("12_allow_all")

[sub_resource type="Resource" id="TargetingSpellSourceSpace"]
script = ExtResource("13_linear_space")

[sub_resource type="Resource" id="TargetingSpellFactory"]
script = ExtResource("14_factory")

[sub_resource type="Resource" id="TargetingAllowAllPolicy"]
script = ExtResource("20_target_allow_all")

[sub_resource type="Resource" id="TargetingSpellSourceConfig"]
script = ExtResource("7_config")
space_model = SubResource("TargetingSpellSourceSpace")
layout_policy = SubResource("TargetingSpellLayout")
display_style = SubResource("TargetingSpellDisplay")
interaction = SubResource("TargetingSpellInteraction")
sort_policy = SubResource("TargetingSpellSort")
transfer_policy = SubResource("TargetingSpellTransferPolicy")
targeting_style = ExtResource("19_classic_style")
targeting_policy = SubResource("TargetingAllowAllPolicy")
drag_visual_factory = SubResource("TargetingSpellFactory")

[sub_resource type="Resource" id="TargetingSpellSpace"]
script = ExtResource("15_square_space")
columns = 4
rows = 2
cell_size = Vector2(84, 84)
cell_spacing = Vector2(12, 12)
padding = Vector2(20, 20)

[sub_resource type="Resource" id="TargetingAbilitySpace"]
script = ExtResource("15_square_space")
columns = 4
rows = 3
cell_size = Vector2(84, 84)
cell_spacing = Vector2(12, 12)
padding = Vector2(20, 20)

[sub_resource type="Resource" id="TargetingBattlefieldLayout"]
script = ExtResource("22_battlefield_layout")

[sub_resource type="Resource" id="TargetingBattlefieldTransferPolicy"]
script = ExtResource("23_occupancy_policy")

[sub_resource type="Resource" id="TargetingSpellTargetConfig"]
script = ExtResource("7_config")
space_model = SubResource("TargetingSpellSpace")
layout_policy = SubResource("TargetingBattlefieldLayout")
display_style = SubResource("TargetingSpellDisplay")
interaction = SubResource("TargetingSpellInteraction")
transfer_policy = SubResource("TargetingBattlefieldTransferPolicy")
targeting_style = ExtResource("19_classic_style")
targeting_policy = SubResource("TargetingAllowAllPolicy")
drag_visual_factory = SubResource("TargetingSpellFactory")

[sub_resource type="Resource" id="TargetingAbilityConfig"]
script = ExtResource("7_config")
space_model = SubResource("TargetingAbilitySpace")
layout_policy = SubResource("TargetingBattlefieldLayout")
display_style = SubResource("TargetingSpellDisplay")
interaction = SubResource("TargetingSpellInteraction")
transfer_policy = SubResource("TargetingBattlefieldTransferPolicy")
targeting_style = ExtResource("19_classic_style")
targeting_policy = SubResource("TargetingAllowAllPolicy")
drag_visual_factory = SubResource("TargetingSpellFactory")

[sub_resource type="Resource" id="TargetingSpellRejectAllies"]
script = ExtResource("17_target_rule")
target_item_script = ExtResource("21_zone_piece")
target_candidate_kind = 1
required_candidate_meta_key = "target_team"
required_candidate_meta_value = "ally"
reject_reason = "This spell only targets enemies."
allowed = false

[sub_resource type="Resource" id="TargetingSpellAllowEnemies"]
script = ExtResource("17_target_rule")
target_item_script = ExtResource("21_zone_piece")
target_candidate_kind = 1
required_candidate_meta_key = "target_team"
required_candidate_meta_value = "enemy"

[sub_resource type="Resource" id="TargetingSpellRuleTable"]
script = ExtResource("16_target_rule_table")
rules = [SubResource("TargetingSpellRejectAllies"), SubResource("TargetingSpellAllowEnemies")]

[sub_resource type="Resource" id="TargetingSpellIntent"]
script = ExtResource("18_target_intent")
policy = SubResource("TargetingSpellRuleTable")
allowed_candidate_kinds = PackedInt32Array(1)
metadata = {
"spell_name": "Meteor"
}

[sub_resource type="Resource" id="TargetingAbilityAllowSquares"]
script = ExtResource("17_target_rule")
target_candidate_kind = 2
placement_target_kind = 2

[sub_resource type="Resource" id="TargetingAbilityRuleTable"]
script = ExtResource("16_target_rule_table")
rules = [SubResource("TargetingAbilityAllowSquares")]

[sub_resource type="Resource" id="TargetingAbilityIntent"]
script = ExtResource("18_target_intent")
policy = SubResource("TargetingAbilityRuleTable")
allowed_candidate_kinds = PackedInt32Array(2)
metadata = {
"ability_name": "Guardian Dash"
}

[node name="TargetingLab" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("2_theme")
spell_style_ids = PackedStringArray("classic", "arcane", "strike", "tactical")
ability_style_ids = PackedStringArray("classic", "arcane", "strike", "tactical")
spell_initial_style_id = &"classic"
ability_initial_style_id = &"tactical"
initial_status_message = "拖拽 Meteor 指向敌方棋子，或切换风格后点击 Aim Ability 体验 style override / Drag Meteor onto an enemy piece, or switch presets and click Aim Ability to preview style overrides"
grid_min_cell_size = 72.0
grid_max_cell_size = 120.0

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoHubMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="TitleLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoHubTitle"
text = "Targeting / 动态箭头选目标"

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoStatusLabel"
autowrap_mode = 3

[node name="ContentRow" type="HFlowContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
theme_type_variation = &"DemoWideFlow"

[node name="SpellColumn" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="SpellLabel" type="Label" parent="RootMargin/RootVBox/ContentRow/SpellColumn"]
layout_mode = 2
theme_type_variation = &"DemoGoldHeading"
text = "Spell Targeting"

[node name="SpellHint" type="Label" parent="RootMargin/RootVBox/ContentRow/SpellColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "Drag the spell card to an enemy piece. Use the preset menu to preview built-in addon styles on drag-entry targeting."

[node name="SpellToolbar" type="HFlowContainer" parent="RootMargin/RootVBox/ContentRow/SpellColumn"]
layout_mode = 2
theme_type_variation = &"DemoToolbarFlow"

[node name="SpellStyleLabel" type="Label" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellToolbar"]
layout_mode = 2
text = "Spell Preset"

[node name="SpellStyleOption" type="OptionButton" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellToolbar"]
layout_mode = 2
size_flags_horizontal = 3

[node name="SpellHandPanel" type="Panel" parent="RootMargin/RootVBox/ContentRow/SpellColumn"]
custom_minimum_size = Vector2(360, 220)
layout_mode = 2

[node name="SpellSourceZone" type="Control" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellHandPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("3_zone")
config = SubResource("TargetingSpellSourceConfig")

[node name="ItemsRoot" type="Control" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellHandPanel/SpellSourceZone"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Meteor" type="Control" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellHandPanel/SpellSourceZone/ItemsRoot"]
custom_minimum_size = Vector2(120, 180)
script = ExtResource("5_example_card")
card_title = "Meteor"
card_cost = 2
card_tags = PackedStringArray("spell", "target")
zone_targeting_intent_override = SubResource("TargetingSpellIntent")

[node name="SpellTargetPanel" type="Panel" parent="RootMargin/RootVBox/ContentRow/SpellColumn"]
custom_minimum_size = Vector2(360, 340)
layout_mode = 2
size_flags_vertical = 3

[node name="SpellTargetZone" type="Control" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellTargetPanel"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("4_battlefield_zone")
config = SubResource("TargetingSpellTargetConfig")

[node name="ItemsRoot" type="Control" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellTargetPanel/SpellTargetZone"]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
mouse_filter = 2

[node name="Bulwark" type="Control" parent="RootMargin/RootVBox/ContentRow/SpellColumn/SpellTargetPanel/SpellTargetZone/ItemsRoot"]
