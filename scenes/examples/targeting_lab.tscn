[node name="AbilityHint" type="Label" parent="RootMargin/RootVBox/ContentRow/AbilityColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "Use explicit begin_targeting() to aim a piece ability at empty or occupied square cells. The preset menu below drives intent.style_override."

[node name="AbilityToolbar" type="HFlowContainer" parent="RootMargin/RootVBox/ContentRow/AbilityColumn"]
layout_mode = 2
