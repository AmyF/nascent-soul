[node name="AbilityColumn" type="VBoxContainer" parent="RootMargin/RootVBox/ContentRow"]
layout_mode = 2
size_flags_horizontal = 3

[node name="AbilityLabel" type="Label" parent="RootMargin/RootVBox/ContentRow/AbilityColumn"]
layout_mode = 2
