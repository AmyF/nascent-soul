corner_radius_top_right = 14
corner_radius_bottom_right = 14
corner_radius_bottom_left = 14

[node name="ZoneRecipes" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("8_theme")
deck_cards = [SubResource("RecipeDeckCardSpark"), SubResource("RecipeDeckCardShell"), SubResource("RecipeDeckCardFocus"), SubResource("RecipeDeckCardGale"), SubResource("RecipeDeckCardEcho"), SubResource("RecipeDeckCardNova")]
hand_cards = [SubResource("RecipeHandCardTether"), SubResource("RecipeHandCardBloom"), SubResource("RecipeHandCardStrike"), SubResource("RecipeHandCardWard")]
board_cards = [SubResource("RecipeBoardCardSentinel"), SubResource("RecipeBoardCardPulse")]

[node name="RootMargin" type="MarginContainer" parent="."]
layout_mode = 1
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
theme_type_variation = &"DemoSceneMargin"

[node name="RootVBox" type="VBoxContainer" parent="RootMargin"]
layout_mode = 2
theme_type_variation = &"DemoRootVBox"

[node name="Toolbar" type="HBoxContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
theme_type_variation = &"DemoToolbarHBox"

[node name="ResetButton" type="Button" parent="RootMargin/RootVBox/Toolbar"]
layout_mode = 2
theme_type_variation = &"DemoPrimaryActionButton"
text = "重置模板 / Reset recipe"

[node name="RecipesGrid" type="GridContainer" parent="RootMargin/RootVBox"]
layout_mode = 2
size_flags_vertical = 3
columns = 4
theme_type_variation = &"DemoRecipeGrid"

[node name="DeckColumn" type="VBoxContainer" parent="RootMargin/RootVBox/RecipesGrid"]
layout_mode = 2
custom_minimum_size = Vector2(200, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="DeckLabel" type="Label" parent="RootMargin/RootVBox/RecipesGrid/DeckColumn"]
layout_mode = 2
theme_type_variation = &"DemoGoldHeading"
text = "牌库模板 / Deck recipe"

[node name="DeckDetails" type="Label" parent="RootMargin/RootVBox/RecipesGrid/DeckColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "PileZonePreset，适合抽牌堆与隐藏堆叠 / PileZonePreset for draw piles and hidden stacks"

[node name="DeckZone" type="Control" parent="RootMargin/RootVBox/RecipesGrid/DeckColumn"]
custom_minimum_size = Vector2(200, 240)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("RecipeDeckZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("3_pile")

[node name="HandColumn" type="VBoxContainer" parent="RootMargin/RootVBox/RecipesGrid"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(260, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="HandLabel" type="Label" parent="RootMargin/RootVBox/RecipesGrid/HandColumn"]
layout_mode = 2
theme_type_variation = &"DemoGreenHeading"
text = "手牌模板 / Hand recipe"

[node name="HandDetails" type="Label" parent="RootMargin/RootVBox/RecipesGrid/HandColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "HandZonePreset，适合手牌与奖励选择 / HandZonePreset for player hands and reward picks"

[node name="HandZone" type="Control" parent="RootMargin/RootVBox/RecipesGrid/HandColumn"]
custom_minimum_size = Vector2(260, 240)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_styles/panel = SubResource("RecipeHandZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("4_hand")

[node name="BoardColumn" type="VBoxContainer" parent="RootMargin/RootVBox/RecipesGrid"]
layout_mode = 2
size_flags_horizontal = 3
custom_minimum_size = Vector2(260, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="BoardLabel" type="Label" parent="RootMargin/RootVBox/RecipesGrid/BoardColumn"]
layout_mode = 2
theme_type_variation = &"DemoBlueHeading"
text = "战场模板 / Board recipe"

[node name="BoardDetails" type="Label" parent="RootMargin/RootVBox/RecipesGrid/BoardColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "BoardZonePreset，容量限制的主动位 / BoardZonePreset for capacity-limited active rows"

[node name="BoardCapacityLabel" type="Label" parent="RootMargin/RootVBox/RecipesGrid/BoardColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "容量 0 / 4 / Capacity 0 / 4"

[node name="BoardZone" type="Control" parent="RootMargin/RootVBox/RecipesGrid/BoardColumn"]
custom_minimum_size = Vector2(260, 240)
layout_mode = 2
size_flags_horizontal = 3
size_flags_vertical = 3
theme_override_styles/panel = SubResource("RecipeBoardZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("5_board")
transfer_policy = SubResource("RecipeBoardCapacityPolicy")

[node name="DiscardColumn" type="VBoxContainer" parent="RootMargin/RootVBox/RecipesGrid"]
layout_mode = 2
custom_minimum_size = Vector2(200, 0)
theme_type_variation = &"DemoColumnVBox"

[node name="DiscardLabel" type="Label" parent="RootMargin/RootVBox/RecipesGrid/DiscardColumn"]
layout_mode = 2
theme_type_variation = &"DemoRoseHeading"
text = "弃牌堆模板 / Discard recipe"

[node name="DiscardDetails" type="Label" parent="RootMargin/RootVBox/RecipesGrid/DiscardColumn"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoDetailLabel"
text = "DiscardZonePreset，适合弃牌堆与回收区 / DiscardZonePreset for discard piles and recovery zones"

[node name="DiscardZone" type="Control" parent="RootMargin/RootVBox/RecipesGrid/DiscardColumn"]
custom_minimum_size = Vector2(200, 240)
layout_mode = 2
size_flags_vertical = 3
theme_override_styles/panel = SubResource("RecipeDiscardZonePanel")
script = ExtResource("2_zone")
preset = ExtResource("6_discard")

[node name="StatusLabel" type="Label" parent="RootMargin/RootVBox"]
layout_mode = 2
autowrap_mode = 3
theme_type_variation = &"DemoStatusLabel"
text = "最近 / Latest: Loading zone recipes..."
