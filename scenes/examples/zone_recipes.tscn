[sub_resource type="StyleBoxFlat" id="RecipeDiscardZonePanel"]
bg_color = Color(0.08, 0.09, 0.12, 0.96)
border_width_left = 2
border_width_top = 2
border_width_right = 2
border_width_bottom = 2
