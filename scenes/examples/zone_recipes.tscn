[gd_scene format=3]

[ext_resource type="Script" path="res://scenes/examples/zone_recipes.gd" id="1_scene"]
[ext_resource type="Theme" path="res://scenes/examples/shared/demo_theme.tres" id="8_theme"]
[ext_resource type="Script" path="res://scenes/examples/shared/example_card_spec.gd" id="9_card_spec"]
[ext_resource type="Script" path="res://addons/nascentsoul/core/zone.gd" id="2_zone"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/pile_zone_preset.tres" id="3_pile"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/hand_zone_preset.tres" id="4_hand"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/board_zone_preset.tres" id="5_board"]
[ext_resource type="Resource" path="res://addons/nascentsoul/presets/discard_zone_preset.tres" id="6_discard"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_capacity_transfer_policy.gd" id="7_capacity"]

[sub_resource type="Resource" id="RecipeBoardCapacityPolicy"]
script = ExtResource("7_capacity")
max_items = 4
reject_reason = "Board recipe 已满。提高 max_items 或先弃掉一张牌。\nBoard recipe is full. Raise max_items or discard a card first."

[sub_resource type="Resource" id="RecipeDeckCardSpark"]
script = ExtResource("9_card_spec")
title = "Spark"
cost = 1
tags = PackedStringArray("attack")

