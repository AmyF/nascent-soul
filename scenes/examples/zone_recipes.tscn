[node name="ZoneRecipes" type="Control"]
layout_mode = 3
anchors_preset = 15
anchor_right = 1.0
anchor_bottom = 1.0
grow_horizontal = 2
grow_vertical = 2
script = ExtResource("1_scene")
theme = ExtResource("8_theme")
ready_status = "Starter recipe 已就绪 / Starter recipe is ready"
reset_status = "模板已重置，可以继续试玩或直接复制这四列 / The recipe board has been reset and is ready to copy"
status_prefix = "最近 / Latest"
board_capacity_format = "容量 %d / %d / Capacity %d / %d"
grid_columns = Vector3i(4, 2, 2)
edge_column_widths = Vector3(200, 176, 164)
middle_column_widths = Vector3(260, 212, 188)
zone_heights = Vector3(240, 210, 184)

