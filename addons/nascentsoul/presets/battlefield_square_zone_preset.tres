[gd_resource type="Resource" script_class="ZonePreset" format=3]

[ext_resource type="Script" path="res://addons/nascentsoul/impl/displays/zone_card_display.gd" id="1_display"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/factories/zone_configurable_drag_visual_factory.gd" id="2_factory"]
[ext_resource type="Script" path="res://addons/nascentsoul/resources/zone_interaction.gd" id="3_interaction"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/layouts/zone_battlefield_layout.gd" id="4_layout"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/permissions/zone_occupancy_permission.gd" id="5_transfer"]
[ext_resource type="Script" path="res://addons/nascentsoul/resources/zone_preset.gd" id="6_preset"]
[ext_resource type="Script" path="res://addons/nascentsoul/impl/spaces/zone_square_grid_space_model.gd" id="7_space"]

[sub_resource type="Resource" id="BattlefieldSquareDisplay"]
script = ExtResource("1_display")

[sub_resource type="Resource" id="BattlefieldSquareFactory"]
script = ExtResource("2_factory")

[sub_resource type="Resource" id="BattlefieldSquareInteraction"]
script = ExtResource("3_interaction")

[sub_resource type="Resource" id="BattlefieldSquareLayout"]
script = ExtResource("4_layout")

[sub_resource type="Resource" id="BattlefieldSquareTransfer"]
script = ExtResource("5_transfer")

[sub_resource type="Resource" id="BattlefieldSquareSpace"]
script = ExtResource("7_space")
columns = 6
rows = 3
cell_size = Vector2(120, 120)
cell_spacing = Vector2(12, 12)
padding = Vector2(18, 18)

[resource]
script = ExtResource("6_preset")
space_model = SubResource("BattlefieldSquareSpace")
layout_policy = SubResource("BattlefieldSquareLayout")
display_style = SubResource("BattlefieldSquareDisplay")
interaction = SubResource("BattlefieldSquareInteraction")
transfer_policy = SubResource("BattlefieldSquareTransfer")
drag_visual_factory = SubResource("BattlefieldSquareFactory")
